# Copy this file to .env and replace placeholder values before running the infra scripts.
# Example: cp env.sample .env

# Terraform / OCI
export TF_VAR_project_name="oracle-ddd-demo"
export TF_VAR_region="sa-saopaulo-1"
export TF_VAR_tenancy_ocid="<tenancy_ocid>"
export TF_VAR_compartment_ocid="<compartment_ocid>"

# OCI authentication.
# Use APIKey with the user/fingerprint/private key fields below, or SecurityToken
# when using an authenticated OCI CLI profile.
export TF_VAR_auth="APIKey"
export TF_VAR_config_file_profile="DEFAULT"
export TF_VAR_user_ocid="<user_ocid>"
export TF_VAR_fingerprint="<api_key_fingerprint>"
export TF_VAR_private_key_path="$HOME/.oci/oci_api_key.pem"
export TF_VAR_private_key_password=""

# Network
export TF_VAR_vcn_cidr="10.0.0.0/16"
export TF_VAR_control_plane_subnet_cidr="10.0.0.0/24"
export TF_VAR_worker_subnet_cidr="10.0.10.0/24"
export TF_VAR_lb_subnet_cidr="10.0.20.0/24"

# OKE
export TF_VAR_kubernetes_version=""
export TF_VAR_node_count="2"
export TF_VAR_node_shape="VM.Standard.E4.Flex"
export TF_VAR_node_ocpus="2"
export TF_VAR_node_memory_in_gbs="16"
export TF_VAR_node_image_id=""
export TF_VAR_node_image_name_filter=""
export TF_VAR_node_pool_os_type="OL8"
export TF_VAR_node_pool_os_arch_override=""
export TF_VAR_ssh_public_key=""
export TF_VAR_pods_cidr="10.244.0.0/16"
export TF_VAR_services_cidr="10.96.0.0/16"

# Image build / OCIR
# Username format: <tenancy-namespace>/<oci-username>
# Federated users usually use: <tenancy-namespace>/<identity-domain>/<username>
export OCIR_USERNAME="<ocir_username>"
export OCIR_AUTH_TOKEN="<ocir_auth_token>"
export IMAGE_TAG="demo"
export DOCKER_PLATFORM=""

# Optional local source overrides. Defaults point to ../backend and ../frontend.
export APP_SRC_DIR=""
export BACKEND_DIR=""
export FRONTEND_DIR=""

# Kubernetes deploy
export K8S_NAMESPACE="copa-ticketing"
export FORCE_ROLLOUT_RESTART="true"
export ROLLOUT_TIMEOUT="600s"

# Backend application
export BACKEND_PORT="8080"
export DB_URL="jdbc:mysql://<host>:3306/copa_ticketing?serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true"
export DB_USER="<db_user>"
export DB_PASS="<db_password>"
export DB_POOL_SIZE="20"
export ADMIN_USER="admin"
export ADMIN_PASS="<admin_password>"
export CUSTOMER_USER="customer"
export CUSTOMER_PASS="<customer_password>"
export OCI_GENAI_API_KEY="<oci_genai_api_key>"
export OCI_GENAI_MODEL_ID="cohere.command-r-plus"

# Frontend application
export FRONTEND_PORT="8081"
export BACKEND_URL="http://copa-backend.copa-ticketing.svc.cluster.local:8080"
export BACKEND_CUSTOMER_USER="customer"
export BACKEND_CUSTOMER_PASS="<customer_password>"
export BACKEND_ADMIN_USER="admin"
export BACKEND_ADMIN_PASS="<admin_password>"
